        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Rotor 2: front_left, CW, axis=[-0.251, 0.428, 0.866025] in FLU -->
    <link name='rotor_2'>
